datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Meeting {
  id           String     @id @default(uuid())
  title        String
  date         String
  summary      String
  transcript   String?
  createdAt    DateTime   @default(now())
  attendees    Attendee[]
}

model Attendee {
  id           String   @id @default(uuid())
  name         String
  role         String?
  actionItems  String
  emailSubject String
  emailBody    String
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}
